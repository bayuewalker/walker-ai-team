# CrusaderBot — Deploy Environment Variables
# Copy to .env and fill in values before deploying.
# Secrets must NEVER be committed to the repository.
#
# Fly.io: set secrets via `fly secrets set VAR=value`
# Local:  copy to .env and use python-dotenv or export manually

# ── REQUIRED — startup fails loudly if these are missing ─────────────────────

# PostgreSQL connection DSN
# Format: postgresql://user:password@host:port/dbname
DB_DSN=postgresql://crusader:changeme@localhost:5432/crusaderbot

# ── TRADING MODE ──────────────────────────────────────────────────────────────

# Trading mode: PAPER (safe, no real orders) | LIVE (real capital)
TRADING_MODE=PAPER

# Required for LIVE mode — explicit opt-in guard. NEVER set to true in paper mode.
# ENABLE_LIVE_TRADING=true

# ── HTTP / FLY.IO ─────────────────────────────────────────────────────────────

# TCP port — Fly.io injects this automatically. Default: 8080
PORT=8080

# ── OPTIONAL SERVICES ─────────────────────────────────────────────────────────

# Redis connection URL (optional — used for caching and pub/sub)
# REDIS_URL=redis://localhost:6379/0

# ── TELEGRAM BOT (optional) ───────────────────────────────────────────────────

# Telegram bot token from @BotFather
# TELEGRAM_BOT_TOKEN=1234567890:AAABBBCCCDDDEEEFFFGGGHHHIII

# Telegram chat ID for operator alerts
# TELEGRAM_CHAT_ID=123456789

# ── MARKET DATA ───────────────────────────────────────────────────────────────

# Comma-separated Polymarket condition IDs, or "auto" for discovery
# MARKET_IDS=0x...,0x...

# ── DASHBOARD ─────────────────────────────────────────────────────────────────

# Enable the optional dashboard server (default: false)
# DASHBOARD_ENABLED=true

# Bearer token for dashboard auth
# DASHBOARD_API_KEY=change-me-in-production

# ── HEARTBEAT (optional tuning) ───────────────────────────────────────────────

# Telegram heartbeat interval in minutes (default: 30)
# HEARTBEAT_INTERVAL_MIN=30
